# =============================================================================
# .env.example — Copy this to .env and fill in your values
# NEVER commit your actual .env file to git
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# Your Railway backend URL (set after first deploy)
APP_URL=https://your-app.railway.app

# ── Telegram ──────────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Generate a random secret string (e.g. run: openssl rand -hex 32)
BOT_SECRET=your_random_secret_string_here

# Your Vercel frontend URL (set after first deploy)
MINI_APP_URL=https://splitmate.vercel.app

# ── Database (Supabase) ───────────────────────────────────────────────────────
# Found in Supabase → Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ── Redis (Upstash) — Optional but recommended ────────────────────────────────
# Found in Upstash → Your database → REST API
REDIS_URL=https://your-redis.upstash.io
REDIS_TOKEN=your_upstash_token

# ── OpenAI (Pro receipt scanning feature) ────────────────────────────────────
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Exchange Rates (multi-currency) ───────────────────────────────────────────
# Free tier at https://openexchangerates.org
EXCHANGE_RATES_API_KEY=your_key_here

# ── Monetization ─────────────────────────────────────────────────────────────
# Pro subscription price in Telegram Stars (500 Stars ≈ $5)
PRO_MONTHLY_STARS=500

# TON settlement fee percentage (0.5 = 0.5%)
TON_FEE_PERCENT=0.5

# =============================================================================
# Frontend (.env in /frontend folder)
# =============================================================================
VITE_API_URL=https://your-app.railway.app
