# =============================================================================
# .gitignore — Never commit these to version control
# =============================================================================

# Environment variables — NEVER commit real secrets
.env
.env.local
.env.production

# Dependencies
node_modules/
*/node_modules/

# Build output
frontend/dist/
frontend/.vercel/

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Railway
.railway/
